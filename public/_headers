/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), autoplay=(self "https://player.vimeo.com"), camera=(), display-capture=(), fullscreen=(self "https://player.vimeo.com"), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(self "https://player.vimeo.com"), publickey-credentials-get=(), usb=(), xr-spatial-tracking=(), interest-cohort=()
  Content-Security-Policy: default-src 'none'; base-uri 'none'; script-src 'self' https://www.googletagmanager.com; style-src 'self'; img-src 'self' data: https://*.google-analytics.com https://*.googletagmanager.com; font-src 'self'; connect-src 'self' https://formspree.io https://*.google-analytics.com https://*.analytics.google.com https://*.googletagmanager.com; frame-src https://player.vimeo.com; form-action https://formspree.io; frame-ancestors 'none'; manifest-src 'self'; object-src 'none'; upgrade-insecure-requests
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

/
  Cache-Control: public, max-age=300, s-maxage=86400

/index.html
  Cache-Control: public, max-age=300, s-maxage=86400

/images/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/styles.css
  Cache-Control: public, max-age=2592000

/site.js
  Cache-Control: public, max-age=2592000

/og-image.jpg
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=2592000

/favicon-32.png
  Cache-Control: public, max-age=2592000

/apple-touch-icon.png
  Cache-Control: public, max-age=2592000

/sitemap.xml
  Cache-Control: public, max-age=3600
